{
     "version": "2.0.0",
     "tasks": [
          {
               "label": "Configure Project",
               "type": "shell",
               "command": "cmake",
               "args": [
                    "--fresh",
                    "--preset",
                    "debug"
               ],
               "options": {
                    "cwd": "${workspaceFolder}"
               }
          },
          {
               "label": "Build Project",
               "type": "shell",
               "command": "cmake",
               "args": [
                    "--build",
                    "--preset",
                    "debug"
               ],
               "options": {
                    "cwd": "${workspaceFolder}"
               },
               "dependsOn": [
                    "Configure Project"
               ],
                "dependsOrder": "sequence",
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "problemMatcher": [
                    "$gcc"
                ]
          }
     ]
}
